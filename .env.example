# ===========================================
# AI Hieu Ban - Backend Environment Variables
# ===========================================
# Copy this file to .env (local), .env.development (dev), or .env.production (prod)

# Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:goclaw@localhost:5432/aihieuban

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# JWT
JWT_SECRET=dev-secret-change-in-production

# SePay Payment
SEPAY_ENV=sandbox
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Mock AI (set to false when Flask service ready)
MOCK_AI=true

# Chat Service (Flask)
CHAT_SERVICE_URL=http://localhost:5001
CHAT_SERVICE_SECRET=dev-service-secret-change-me
